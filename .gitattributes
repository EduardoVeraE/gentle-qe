# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicit overrides for binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar.gz binary

# --- Overlay Gentle-QE: archivos 100% del fork ---
# Resuelven a favor del fork en cada `git merge upstream/main` (driver merge=ours).
# Habilitar el driver una vez por clon:  git config merge.ours.driver true
# tools/qe-overlay igual reporta los cambios upstream relevantes para incorporarlos a mano.
README.md                      merge=ours
.goreleaser.yaml               merge=ours
scripts/install.sh             merge=ours
.github/workflows/pr-check.yml merge=ours
